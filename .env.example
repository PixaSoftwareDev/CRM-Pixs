# PIXS — Environment Variables
# Copy to .env and adjust for your environment.
# All variables are prefixed with PIXS_.

# HTTP server port
PIXS_HTTP_PORT=8080

# PostgreSQL connection string (pgx/v5 DSN format)
# Dev: matches docker-compose.yml defaults
PIXS_DATABASE_URL=postgres://pixs:pixs_dev@localhost:5433/pixs_dev?sslmode=disable

# Redis connection URL
# Dev: matches docker-compose.yml defaults
PIXS_REDIS_URL=redis://localhost:6379/0

# Runtime environment: dev | staging | prod
PIXS_ENVIRONMENT=dev

# Log level: debug | info | warn | error
PIXS_LOG_LEVEL=info

# CORS: comma-separated list of allowed origins
# Use * only in dev — never in prod
PIXS_CORS_ALLOWED_ORIGINS=http://localhost:3000
